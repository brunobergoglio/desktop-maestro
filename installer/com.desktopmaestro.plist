<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.desktopmaestro</string>

	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/desktopmaestro</string>
		<string>organize</string>
		<string>--headless</string>
	</array>

	<key>StartInterval</key>
	<integer>21600</integer>

	<key>RunAtLoad</key>
	<true/>

	<key>StandardOutPath</key>
	<string>/Users/brunitobe/Library/Logs/DesktopMaestro/launchd.stdout.log</string>

	<key>StandardErrorPath</key>
	<string>/Users/brunitobe/Library/Logs/DesktopMaestro/launchd.stderr.log</string>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>

	<key>ProcessType</key>
	<string>Background</string>

	<key>Nice</key>
	<integer>1</integer>

	<key>KeepAlive</key>
	<false/>
</dict>
</plist>
